{
  "name": "yarrtorio-electron",
  "version": "2026.3.26.1",
  "private": true,
  "description": "Yarrtorio - Factorio mod downloader and manager built with Electron, Vite, React, Tailwind CSS, and daisyUI.",
  "main": "out/main/index.js",
  "author": "Auserwaulth",
  "type": "module",
  "scripts": {
    "version:date": "node scripts/set-date-version.mjs",
    "dev": "npm run version:date && electron-vite dev",
    "build": "npm run version:date && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "dist": "npm run build && electron-builder --win portable nsis --x64",
    "dist:linux": "npm run build && electron-builder --linux AppImage --x64",
    "dist:linux:arm64": "npm run build && electron-builder --linux AppImage --arm64",
    "format": "prettier . --write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "daisyui": "^5.0.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "com.yarrtorio.app",
    "productName": "Yarrtorio",
    "directories": {
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/icons",
        "to": "icons"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": false,
      "installerIcon": "resources/icons/icon.ico",
      "uninstallerIcon": "resources/icons/icon.ico",
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Game",
      "icon": "resources/icons"
    },
    "appImage": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Auserwaulth",
        "repo": "yarrtorio-electron"
      }
    ]
  }
}
